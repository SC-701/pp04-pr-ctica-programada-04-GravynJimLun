@page
@model Web.Pages.Vehiculos.EditarModel
@{
}

<header class="bg-dark text-white py-5 mb-5">
    <div class="container text-center">
        <h1 class="fw-bold">Editar Vehículo</h1>
        <p class="lead">SC-701 Programación Web Avanzada</p>
    </div>
</header>

<section class="container">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-secondary text-dark">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Editar Información
                    </h4>
                </div>

                <div class="card-body">

                    <form method="post">

                        <div class="mb-3">
                            <label class="form-label">Marca</label>

                            <select asp-for="marcaSeleccionada"
                                    class="form-select"
                                    asp-items="Model.marcas"
                                    id="marcas"
                                    onchange="fetchModelos()">

                                <option value="">Seleccione una marca</option>

                            </select>

                            <span class="text-danger" asp-validation-for="vehiculo.Marca"></span>
                        </div>


                        <div class="mb-3">
                            <label class="form-label">Modelo</label>

                            <select asp-for="modeloSeleccionado"
                                    class="form-select"
                                    asp-items="Model.modelos"
                                    id="modelos">

                                <option value="">Seleccione un modelo</option>

                            </select>

                            <span class="text-danger" asp-validation-for="vehiculo.Modelo"></span>
                        </div>


                        <div class="mb-3">
                            <label asp-for="vehiculo.Placa" class="form-label"></label>
                            <input asp-for="vehiculo.Placa" class="form-control" />
                            <span class="text-danger" asp-validation-for="vehiculo.Placa"></span>
                        </div>


                        <div class="mb-3">
                            <label asp-for="vehiculo.Precio" class="form-label"></label>
                            <input asp-for="vehiculo.Precio" class="form-control" />
                            <span class="text-danger" asp-validation-for="vehiculo.Precio"></span>
                        </div>


                        <div class="mb-3">
                            <label asp-for="vehiculo.Anio" class="form-label"></label>
                            <input asp-for="vehiculo.Anio" class="form-control" />
                            <span class="text-danger" asp-validation-for="vehiculo.Anio"></span>
                        </div>


                        <div class="mb-3">
                            <label asp-for="vehiculo.Color" class="form-label"></label>
                            <input asp-for="vehiculo.Color" class="form-control" />
                            <span class="text-danger" asp-validation-for="vehiculo.Color"></span>
                        </div>


                        <div class="mb-3">
                            <label asp-for="vehiculo.CorreoPropietario" class="form-label"></label>
                            <input asp-for="vehiculo.CorreoPropietario" class="form-control" />
                            <span class="text-danger" asp-validation-for="vehiculo.CorreoPropietario"></span>
                        </div>


                        <div class="mb-3">
                            <label asp-for="vehiculo.TelefonoPropietario" class="form-label"></label>
                            <input asp-for="vehiculo.TelefonoPropietario" class="form-control" />
                            <span class="text-danger" asp-validation-for="vehiculo.TelefonoPropietario"></span>
                        </div>


                        <div class="text-danger mb-3" asp-validation-summary="All"></div>


                        <div class="d-flex justify-content-between">

                            <a class="btn btn-outline-secondary"
                               asp-page="./Index">
                                <i class="bi bi-arrow-left"></i> Regresar
                            </a>

                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Guardar Cambios
                            </button>

                        </div>


                        <input type="hidden" asp-for="vehiculo.Id" />
                        <input type="hidden" asp-for="modeloSeleccionado" />
                        <input type="hidden" asp-for="marcaSeleccionada" />

                    </form>

                </div>

            </div>

        </div>

    </div>

</section>

@section Scripts {
    <script>async function fetchModelos() {
            const marcaId = document.getElementById('marcas').value;
            if (!marcaId) {
                return;
            }
            try {
                const response = await fetch(`?handler=ObtenerModelos&marcaId=${marcaId}`);
                if (!response.ok) {
                    throw new Error('Error obteniendo los datos');
                }
                const modelos = await response.json();
                const modelosSelect = document.getElementById('modelos');
                modelosSelect.innerHTML = '<option value="">Seleccione un modelo</option>';
                modelos.forEach(modelo => {
                    const option = document.createElement('option');
                    option.value = modelo.id;
                    option.text = modelo.nombre;
                    modelosSelect.appendChild(option);
                });
            } catch (error) {
                console.error('Error obteniendo los datos:', error);
            }
        }</script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}